{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "dist",
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": [
    "src/**/*"
  ],
}